---
import ThemeSelector from './ThemeSelector.svelte';
---

<header class="header-bar text-white p-4 shadow-md transition-all duration-300">
  <div class="container mx-auto flex justify-between items-center pl-4 pr-4">
    <div class="flex items-center">
      <div class="relative group">
        <button id="menu-toggle" class="focus:outline-none mr-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <nav id="menu" class="nav-menu hidden absolute left-0 mt-2 w-48 rounded shadow-lg z-10 transition-all duration-300">
          <ul class="py-1">
            <li><a href="/" class="block px-4 py-2 nav-link transition-colors duration-200">Home</a></li>
            <li><a href="/about" class="block px-4 py-2 nav-link transition-colors duration-200">About</a></li>
          </ul>
        </nav>
      </div>
      <h1 class="text-xl font-bold"><a href="/" class="hover:underline">Tailspin Shelter</a></h1>
    </div>
    <div class="flex items-center">
      <ThemeSelector client:load />
    </div>
  </div>
</header>

<script>
  // Toggle menu visibility when hamburger is clicked
  const MENU_TOGGLE = document.getElementById('menu-toggle');
  const MENU = document.getElementById('menu');
  
  if (MENU_TOGGLE && MENU) {
    MENU_TOGGLE.addEventListener('click', () => {
      MENU.classList.toggle('hidden');
    });
    
    // Close menu when clicking outside
    document.addEventListener('click', (EVENT) => {
      const IS_CLICK_INSIDE = MENU_TOGGLE.contains(EVENT.target as Node) || MENU.contains(EVENT.target as Node);
      if (!IS_CLICK_INSIDE && !MENU.classList.contains('hidden')) {
        MENU.classList.add('hidden');
      }
    });
  }
</script>